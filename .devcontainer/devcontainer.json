{
  "name": "Battleship Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/IdeaProjects/Battleship2",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "yzhang.markdown-all-in-one"
      ]
    },
    "jetbrains": {
      "backend": "IntelliJIdea",
      "plugins": [
        "Docker",
        "org.jetbrains.plugins.github"
      ],
      "projectSettings": {
        "jdk": {
          "name": "corretto-21",
          "homePath": "/usr/lib/jvm/corretto-21"
        }
      }
    }
  },
  "postCreateCommand": "git config --global --add safe.directory /IdeaProjects/Battleship2 && ln -sf /usr/lib/jvm/java-21-amazon-corretto /usr/lib/jvm/corretto-21 && mvn clean compile -q",
  "remoteEnv": {
    "JAVA_HOME": "/usr/lib/jvm/java-21-amazon-corretto",
    "PATH": "/usr/lib/jvm/java-21-amazon-corretto/bin:${containerEnv:PATH}",
    "GIT_DISCOVERY_ACROSS_FILESYSTEM": "1",
    "DOCKER_ENV": "true",
    "JAVA_TOOL_OPTIONS": "-Djava.awt.headless=true"
  }
}