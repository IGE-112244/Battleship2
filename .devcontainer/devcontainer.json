{
  "name": "Battleship Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "yzhang.markdown-all-in-one"
      ]
    }
  },
  "postCreateCommand": "mvn clean compile -DskipTests",
  "remoteUser": "root"
}